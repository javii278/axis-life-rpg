# DATABASE_URL=postgresql://axis:password@localhost:5432/axis

# ── IA Coach ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (recuperación de contraseña) ────────────────────
# Sin configurar: el enlace aparece en la consola del backend (modo dev)
# Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Contraseña de aplicación, no tu contraseña normal

# URL pública de la app (para el enlace del email)
# APP_URL=https://tudominio.com
