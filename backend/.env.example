# ── Auth ──────────────────────────────────────────────────────────────────────
# OBLIGATORIO: genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA-ESTO-ES-INSEGURO-usa-secrets.token_hex(32)

# ── Base de datos ──────────────────────────────────────────────────────────────
# Omitir para usar SQLite local (axis.db) — solo válido en desarrollo
# Para producción usar PostgreSQL:
# DATABASE_URL=postgresql://axis_user:password@localhost:5432/axis_db
# Render/Railway usan el formato postgres:// — se convierte automáticamente

# ── IA Coach ──────────────────────────────────────────────────────────────────
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── CORS (frontend) ────────────────────────────────────────────────────────────
# En producción, especifica tu dominio exacto (sin trailing slash):
# CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com
# En dev localhost:3000 está permitido por defecto

# ── URL pública de la app ──────────────────────────────────────────────────────
# Usada en los emails (reset password, bienvenida)
APP_URL=https://tudominio.com

# ── Email SMTP ─────────────────────────────────────────────────────────────────
# Sin configurar: los enlaces de reset aparecen en la consola (modo dev)
# Gmail: activa "Contraseñas de aplicación" en myaccount.google.com > Seguridad
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # App password, NO tu contraseña normal

# ── Servidor ───────────────────────────────────────────────────────────────────
# PORT=8000
